{
  "name": "innopulse360",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start:backend": "npm --workspace packages/backend run start",
    "dev:backend": "npm --workspace packages/backend run dev",
    "start:frontend": "npm --workspace packages/frontend run preview",
    "dev:frontend": "npm --workspace packages/frontend run dev",
    "bootstrap": "npm install --workspaces"
  }
}
